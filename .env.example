# ════════════════════════════════════════════════════════════════════════════
# PDF RAG Assistant — Environment Configuration
# Copy this file to .env and adjust as needed.
# ════════════════════════════════════════════════════════════════════════════

# ── Local LLM ────────────────────────────────────────────────────────────────
# HuggingFace repo + filename to auto-download on first run (~5 GB).
# The file is cached in ~/.cache/huggingface/ and reused on subsequent runs.
MODEL_REPO=bartowski/Ministral-8B-Instruct-2410-GGUF
MODEL_FILENAME=Ministral-8B-Instruct-2410-Q4_K_M.gguf

# If you already have the .gguf file locally, set this instead (skips download):
# MODEL_PATH=/absolute/path/to/Ministral-8B-Instruct-2410-Q4_K_M.gguf

# llama.cpp inference parameters
# N_CTX=8192          # context window in tokens (default: 8192)
# N_GPU_LAYERS=-1     # -1 = all layers on GPU, 0 = CPU only (default: -1)
# N_THREADS=8         # CPU threads (default: 8)
# N_BATCH=512         # prompt processing batch size (default: 512)

# Generation
# MAX_TOKENS=1024
# TEMPERATURE=0.1

# ── Embeddings ────────────────────────────────────────────────────────────────
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_DEVICE=cpu      # cpu | cuda | mps
# EMBEDDING_BATCH_SIZE=32

# ── Vector store ──────────────────────────────────────────────────────────────
# VECTORSTORE_DIR=data/vectorstore
# COLLECTION_NAME=rag_documents

# ── Chunking ──────────────────────────────────────────────────────────────────
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# ── Retrieval ─────────────────────────────────────────────────────────────────
# RETRIEVAL_K=5
# MAX_DISTANCE=1.4

# ── Paths ─────────────────────────────────────────────────────────────────────
# DOCUMENTS_DIR=data/documents

# ── HuggingFace token (only needed for gated/private models) ──────────────────
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
